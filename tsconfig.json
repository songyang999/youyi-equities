{
	"compilerOptions": {
		"target": "esnext",
		"useDefineForClassFields": true,
		"module": "esnext",
		"moduleResolution": "node",
		"strict": true,
		"jsx": "preserve",
		"sourceMap": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"noImplicitAny": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"types": ["@dcloudio/types", "uni-app", "webpack-env"],
		"typeRoots": ["types", "node_modules/@types", "node_modules/@dcloudio/types"],
		"paths": {
			"@/*": ["./src/*"]
		},
		"lib": [
			"esnext",
			"dom",
			"dom.iterable",
			"scripthost"
		]
	},
	"vueCompilerOptions": {
		"nativeTags": ["block", "component", "template", "slot"]
	},
	"exclude": [
		"node_modules"
	],
	"include": ["src/**/*.js", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"]
}
